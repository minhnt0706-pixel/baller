# =============================================================================
# Baller Backend — Environment Variables Example
# Copy this file to .env and fill in real values. Never commit .env to git.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=development
# APP_ENV options: development | staging | production
# In non-development mode CORS_ORIGINS must NOT contain '*'

SECRET_KEY=change-me-to-a-random-32-char-string

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://baller_user:baller_pass@localhost:5432/baller_db

# Separate sync URL used by Alembic migrations
ALEMBIC_DATABASE_URL=postgresql+psycopg2://baller_user:baller_pass@localhost:5432/baller_db

# ---------------------------------------------------------------------------
# Redis (used by slowapi rate-limiter)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# VietQR / Payment
# ---------------------------------------------------------------------------
# Bank BIN — look up your bank at https://api.vietqr.io/v2/banks
VIETQR_BANK_ID=970422
# Account number at that bank (no spaces)
VIETQR_ACCOUNT_NO=0123456789
# Account holder name (displayed on QR)
VIETQR_ACCOUNT_NAME=CONG TY BALLER VN
# VietQR template: compact | qr_only | compact2 | print
VIETQR_TEMPLATE=compact2

# ---------------------------------------------------------------------------
# CORS
# Comma-separated list of allowed origins (no trailing slash, no spaces).
# Example: https://app.baller.vn,https://admin.baller.vn
# Using '*' is only allowed when APP_ENV=development.
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
# Maximum booking POSTs allowed from a single IP per RATE_LIMIT_WINDOW_SECONDS
RATE_LIMIT_BOOKING_MAX=10
RATE_LIMIT_WINDOW_SECONDS=60

# ---------------------------------------------------------------------------
# Booking expiry (background task)
# ---------------------------------------------------------------------------
# How many minutes a pending_payment booking is held before it is released
BOOKING_EXPIRY_MINUTES=10

# ---------------------------------------------------------------------------
# Timezone (do not change — Vietnamese law requires Asia/Ho_Chi_Minh)
# ---------------------------------------------------------------------------
TZ=Asia/Ho_Chi_Minh

# ---------------------------------------------------------------------------
# Seed / Crawler (optional — only needed when running seed_db)
# ---------------------------------------------------------------------------
# Facebook group URL to crawl for court data (fallback: courts_data.json)
FB_GROUP_URL=https://www.facebook.com/groups/603786827732066
# Optional: Facebook session cookie value (_js_datr / xs) for authenticated crawl
FB_SESSION_COOKIE=
